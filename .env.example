# CryptoPro Trader — environment configuration
# Copy to ".env" (or set these in your shell/host) as needed.
# Authentication is application-only (username + password), same method as
# CryptoPro Charts and CryptoPro Suite — no third-party SSO credentials
# required.

# Port the server listens on (default 3000).
# PORT=3000

# Set to "production" to mark session cookies Secure (HTTPS only).
# NODE_ENV=production

# --- Supabase (Postgres) — accounts & sessions persistence (single sign-on) ---
# To make this project's login reuse the SAME accounts as CryptoPro Charts /
# CryptoPro Suite (one shared Supabase database across the suite, Suite
# workflow rule 18), point this at Charts' own Supabase Postgres project —
# i.e. use the exact same connection string configured there. Tables are
# created with "create table if not exists", so pointing at Charts' existing
# database is a no-op on the schema.
# DBCRYPTOCHARTS_POSTGRES_URL="postgresql://...:6543/postgres?sslmode=require"
# DBCRYPTOCHARTS_POSTGRES_URL_NON_POOLING="postgresql://...:5432/postgres?sslmode=require"
# (This project's own `trading_POSTGRES_URL*` vars, if set by a separate
# Vercel Supabase integration, are used as a fallback only — pointing at a
# different Supabase project there means accounts won't be shared suite-wide.)
# (generic fallbacks also accepted: POSTGRES_URL_NON_POOLING, POSTGRES_URL, DATABASE_URL)

# Without a connection string the database is disabled and sign-in/register
# return 503 — the rest of the dashboard still works.

# --- Cron cutover (Suite roadmap, "For Trader only") ---
# Vercel Cron (see vercel.json) triggers /api/cron/evaluate|watchdog|
# daily-summary with an `Authorization: Bearer $CRON_SECRET` header when this
# is set on the Vercel project — set it there (Vercel auto-injects it into
# CRON_SECRET when you use the "Vercel Cron Jobs" integration, or set your
# own random value and it's sent verbatim). Without it, the cron endpoints
# only accept a signed-in dashboard session (manual "Run now"), so scheduled
# runs silently 401 until this is set.
# CRON_SECRET=

# Accounts are shared Suite-wide (any CryptoPro Charts/Training/Suite account
# can sign in here too, registration is open) — but the cron routes' manual
# "Run now" trigger and per-job enable/disable toggle control ONE shared
# trading engine, not caller-owned data, so they're restricted to a single
# owner account instead of "any signed-in account". Set this to your account
# id (the lowercase username you registered with). Unset = those two routes
# are disabled for everyone (fail closed) — scheduled runs via CRON_SECRET
# are unaffected either way.
# TRADER_OWNER_UID=

# Gates real order placement from the cron routes, same shape as the CLI's
# `--execute` flag. MUST stay unset/false until the three-gate cutover
# checkpoint (memory/claude_md_archive.md "Node.js port": frozen-fixture
# parity, >=24h live shadow-run parity, state round-trip) has actually been
# run — this is not a "flip when ready" toggle to set casually, the live
# trading engine is still 100% Python and this must not race it into placing
# duplicate orders.
# CRON_EXECUTE=false
